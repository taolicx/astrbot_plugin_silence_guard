{
  "enabled": {
    "type": "bool",
    "description": "启用插件",
    "default": true
  },
  "enable_private": {
    "type": "bool",
    "description": "私聊启用",
    "default": true
  },
  "enable_group": {
    "type": "bool",
    "description": "群聊启用",
    "default": true
  },
  "smart_mode": {
    "type": "bool",
    "description": "启用智能模式",
    "hint": "规则无法确定时，调用 AstrBot 已接入的模型做一次分类判断。",
    "default": true
  },
  "judge_mode": {
    "type": "string",
    "description": "判断模型调用模式",
    "options": ["ambiguous_only"],
    "default": "ambiguous_only"
  },
  "judge_provider_id": {
    "type": "string",
    "description": "判断模型提供商",
    "_special": "select_provider",
    "hint": "留空时默认使用 AstrBot 当前正在使用的 LLM 提供商。"
  },
  "judge_timeout_seconds": {
    "type": "float",
    "description": "判断请求超时秒数",
    "default": 3
  },
  "judge_max_tokens": {
    "type": "int",
    "description": "判断模型最大输出 token",
    "default": 96
  },
  "judge_context_turns": {
    "type": "int",
    "description": "传给判断模型的最近上下文轮数",
    "default": 6
  },
  "judge_min_confidence": {
    "type": "float",
    "description": "判断模型最低置信度",
    "hint": "低于该值时按 fallback_when_uncertain 处理。",
    "default": 0.72
  },
  "judge_cache_seconds": {
    "type": "int",
    "description": "判断结果缓存秒数",
    "default": 120
  },
  "fallback_when_uncertain": {
    "type": "string",
    "description": "不确定时的默认行为",
    "options": ["reply", "no_reply"],
    "default": "reply"
  },
  "default_mute_seconds": {
    "type": "int",
    "description": "闭嘴类指令默认静默秒数",
    "default": 600
  },
  "farewell_cooldown_seconds": {
    "type": "int",
    "description": "互道晚安/拜拜后的收尾冷却秒数",
    "default": 1800
  },
  "active_chat_seconds": {
    "type": "int",
    "description": "最近机器人回复后视为连续对话的秒数",
    "default": 300
  },
  "reply_once_to_farewell": {
    "type": "bool",
    "description": "允许机器人对用户首次晚安/拜拜回复一次",
    "default": true
  },
  "silence_keywords": {
    "type": "list",
    "description": "闭嘴/别回复类关键词",
    "hint": "内置常用说法，面板里可直接增删。用于明确要求机器人安静、别接话、不要回复。",
    "default": [
      "闭嘴",
      "别回",
      "别回我",
      "不回",
      "不回我",
      "不要回",
      "不用回",
      "不回复",
      "别回复",
      "不要回复",
      "不用回复",
      "不说话",
      "无需回复",
      "不必回复",
      "别说了",
      "别说话",
      "不要说话",
      "先别说话",
      "安静",
      "住口",
      "别吵",
      "别搭话",
      "别接话",
      "别搭理我",
      "别理我",
      "不用理我",
      "别管我",
      "别烦我",
      "别来烦我",
      "别打扰",
      "不要打扰",
      "停一下",
      "暂停回复",
      "静默",
      "保持沉默",
      "mute",
      "silence",
      "shut up",
      "be quiet",
      "stop talking"
    ]
  },
  "farewell_keywords": {
    "type": "list",
    "description": "晚安/拜拜类收尾词",
    "hint": "用于识别互道晚安、拜拜、下线等礼貌收尾，避免机器人继续循环回复。",
    "default": [
      "晚安",
      "睡了",
      "我睡了",
      "准备睡了",
      "睡觉了",
      "去睡了",
      "困了",
      "拜拜",
      "拜",
      "拜了",
      "再见",
      "先走了",
      "我走了",
      "886",
      "88",
      "下了",
      "我下了",
      "撤了",
      "溜了",
      "回头聊",
      "明天聊",
      "下次聊",
      "bye",
      "good night",
      "gn"
    ]
  },
  "wake_keywords": {
    "type": "list",
    "description": "恢复回复类关键词",
    "hint": "命中这些词时解除静默，让机器人重新正常回复。",
    "default": [
      "继续",
      "出来",
      "可以说话了",
      "恢复回复",
      "解除静默",
      "取消静默",
      "别闭嘴了",
      "不用闭嘴了",
      "说话",
      "你说",
      "回答我",
      "回我",
      "在吗",
      "醒醒",
      "继续说",
      "接着说",
      "可以回复了",
      "开口",
      "回来",
      "resume",
      "unmute"
    ]
  },
  "hard_closers": {
    "type": "list",
    "description": "强收尾短语",
    "hint": "用户明确表达结束、打住、别继续时直接不回复。",
    "default": [
      "先这样",
      "就这样",
      "到此为止",
      "不聊了",
      "别聊了",
      "这个不聊了",
      "先不聊了",
      "不用管了",
      "你不用管",
      "不用分析",
      "不用解释",
      "不用回复",
      "别回复",
      "不要回复",
      "别理我",
      "不用理我",
      "不用继续了",
      "别继续了",
      "结束吧",
      "结束",
      "停",
      "停一下",
      "打住",
      "别展开",
      "不用展开",
      "我想静静",
      "让我静静",
      "回头再说",
      "以后再说",
      "先不说了",
      "算了吧"
    ]
  },
  "ack_keywords": {
    "type": "list",
    "description": "短确认/附和词",
    "hint": "连续对话里命中这些短回复时，通常交给智能模式判断是不是该收住。",
    "default": [
      "嗯",
      "嗯嗯",
      "恩",
      "恩恩",
      "昂",
      "哦",
      "哦哦",
      "噢",
      "噢噢",
      "好",
      "好的",
      "好吧",
      "行",
      "行吧",
      "成",
      "可以",
      "ok",
      "okok",
      "okk",
      "okay",
      "收到",
      "明白",
      "了解",
      "知道了",
      "懂了",
      "是的",
      "对",
      "对的",
      "对对",
      "没事",
      "没事了",
      "没问题",
      "不用了",
      "算了",
      "行了",
      "可以了",
      "差不多",
      "就这样吧"
    ]
  },
  "debug_log": {
    "type": "bool",
    "description": "输出调试日志",
    "default": false
  }
}
